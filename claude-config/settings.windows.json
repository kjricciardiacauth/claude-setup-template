{
  "skillListingBudgetFraction": 0.02,
  "permissions": {
    "allow": [
      "Bash(rg:*)",
      "Bash(fd:*)",
      "Bash(bat:*)",
      "Bash(fzf:*)",
      "Bash(jq:*)",
      "Bash(xh:*)",
      "Bash(zoxide:*)",
      "Bash(z:*)"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "shell": "powershell",
            "command": "Write-Output '{\"hookSpecificOutput\":{\"hookEventName\":\"SessionStart\",\"additionalContext\":\"BUILD AUTHORIZATION REQUIRED: Do not write code, edit files, push commits, or deploy until the user types build, go ahead, or equivalent explicit approval. Default mode is planning, design, discussion, and code review until then.\"}}'",
            "statusMessage": "Build auth reminder..."
          },
          {
            "type": "command",
            "shell": "powershell",
            "command": "& \"$env:USERPROFILE\\.claude\\hooks\\session-log-start.ps1\"",
            "statusMessage": "Logging session start..."
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "shell": "powershell",
            "command": "& \"$env:USERPROFILE\\.claude\\hooks\\pre-compact-rules.ps1\"",
            "statusMessage": "Re-injecting hard rules before compaction..."
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Agent",
        "hooks": [
          {
            "type": "command",
            "shell": "powershell",
            "command": "Write-Output '{\"hookSpecificOutput\":{\"hookEventName\":\"PreToolUse\",\"additionalContext\":\"AGENT SPAWN CHECK: Before spawning, state estimated tokens out loud (web research=70-100K, file work=30-60K, MCP probes=40-80K). The agent prompt MUST include: (1) Maximum N tool calls total. Hard stop. (2) Maximum N WebFetch calls. (3) Return at cap even if incomplete. Soft TOKEN CAP lines do NOT work - use tool call caps. If combined parallel estimate exceeds 30% of remaining window, switch to sequential or ask user.\"}}'",
            "statusMessage": "Agent spawn check..."
          }
        ]
      },
      {
        "matcher": "mcp__.*__(list|search)_",
        "hooks": [
          {
            "type": "command",
            "shell": "powershell",
            "command": "Write-Output '{\"hookSpecificOutput\":{\"hookEventName\":\"PreToolUse\",\"additionalContext\":\"PROBE BEFORE PULL: page_size=1 first to confirm shape and total_items. Skip only if this exact tool+filter was already probed this session.\"}}'",
            "statusMessage": "Probe-before-pull check..."
          }
        ]
      },
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "shell": "powershell",
            "command": "& \"$env:USERPROFILE\\.claude\\hooks\\pre-write-sensitive-path.ps1\"",
            "statusMessage": "Sensitive path check..."
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "shell": "powershell",
            "command": "& \"$env:USERPROFILE\\.claude\\hooks\\pre-bash-git-dangerous.ps1\"",
            "statusMessage": "Dangerous git check..."
          },
          {
            "type": "command",
            "shell": "powershell",
            "command": "& \"$env:USERPROFILE\\.claude\\hooks\\pre-bash-github-identity.ps1\"",
            "statusMessage": "GitHub identity check..."
          }
        ]
      },
      {
        "matcher": "Write|Edit|MultiEdit|NotebookEdit|Bash",
        "hooks": [
          {
            "type": "command",
            "shell": "powershell",
            "command": "& \"$env:USERPROFILE\\.claude\\hooks\\session-log-toolcall.ps1\"",
            "statusMessage": "Logging tool call..."
          }
        ]
      },
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "shell": "powershell",
            "command": "& \"$env:USERPROFILE\\.claude\\hooks\\pre-write-secrets-scan.ps1\"",
            "statusMessage": "Secrets scan..."
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "shell": "powershell",
            "command": "& \"$env:USERPROFILE\\.claude\\hooks\\post-bash-git-push.ps1\"",
            "statusMessage": "Checking deployment log..."
          }
        ]
      },
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "shell": "powershell",
            "command": "& \"$env:USERPROFILE\\.claude\\hooks\\post-edit-mcp-docs.ps1\"",
            "statusMessage": "Checking docs..."
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "shell": "powershell",
            "command": "& \"$env:USERPROFILE\\.claude\\hooks\\stop-end-of-turn.ps1\"",
            "statusMessage": "End-of-turn checklist..."
          },
          {
            "type": "command",
            "shell": "powershell",
            "command": "& \"$env:USERPROFILE\\.claude\\hooks\\stop-verify-gate.ps1\"",
            "statusMessage": "Verify gate check..."
          }
        ]
      }
    ]
  }
}
